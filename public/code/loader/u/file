function createFile(type, name, content, auto)
	local function find(path)
		local parts = string.split(path, "/")
		local current = ""
		for i = 1, #parts - 1 do
			current = current .. (i == 1 and parts[i] or "/" .. parts[i])
			if not isfolder(current) then
				makefolder(current)
			end
		end
	end

	if auto then
		if string.find(name, "%.") then
			type = "file"
		else
			type = "folder"
		end
	end

	if type == "folder" then
		if not isfolder(name) then
			makefolder(name)
		end
	elseif type == "file" then
		find(name)
		if isfile(name) then
			appendfile(name, content or "")
		else
			writefile(name, content or "")
		end
	end
end
